.upload-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 20px;
  border: 2px dashed #ddd;
  border-radius: 12px;
  background: #FAFAFE;
}
.upload-zone:active {
  border-color: #4F46E5;
  background: #F0EFFF;
}
.upload-icon { font-size: 40px; margin-bottom: 8px; }
.upload-text { font-size: 15px; color: #666; }
.upload-hint { font-size: 12px; color: #999; margin-top: 8px; }
.status-item { padding: 8px 0; }
.status-text { font-size: 14px; color: #666; }
.section-title { font-size: 15px; font-weight: 600; color: #333; display: block; margin-bottom: 12px; }
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f0f0f0;
}
.file-name { font-size: 14px; color: #333; max-width: 70%; overflow: hidden; text-overflow: ellipsis; }
.file-status { font-size: 12px; }
.file-status.success { color: #34D399; }
