/**app.wxss**/
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
}
.page-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  padding: 16px 20px 12px;
}
.card {
  background: #fff;
  border-radius: 12px;
  margin: 0 16px 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.btn-primary {
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  color: white;
  border: none;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 15px;
  font-weight: 500;
  text-align: center;
  width: 100%;
}
.btn-primary:active {
  opacity: 0.8;
}
.empty-state {
  text-align: center;
  padding: 40px 20px;
  color: #999;
  font-size: 14px;
}
